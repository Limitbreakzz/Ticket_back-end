datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  sourceTickets  Ticket[]         @relation("TicketSourceDepartment")
  targetTickets  Ticket[]         @relation("TicketTargetDepartment")
  transfersFrom  TicketTransfer[]  @relation("TransferFromDepartment")
  transfersTo    TicketTransfer[]  @relation("TransferToDepartment")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  password     String?
  role         String   // "USER", "ADMIN", "MANAGER"
  avatarUrl    String?  @db.LongText
  departmentId String?
  createdAt    DateTime @default(now())

  department       Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  ticketsCreated   Ticket[]        @relation("UserTickets")
  ticketsAssigned  Ticket[]        @relation("AgentTickets")
  comments         Comment[]
  transfersCreated TicketTransfer[] @relation("TransferRequestedBy")
  notifications    Notification[]
}

model Ticket {
  id                 String   @id @default(uuid())
  title              String
  description        String   @db.Text
  status             String   @default("NEW")    // "NEW", "IN_PROGRESS", "RESOLVED", "CANCELLED"
  priority           String   @default("MEDIUM") // "LOW", "MEDIUM", "HIGH", "CRITICAL"
  category           String   // "HARDWARE", "SOFTWARE", "NETWORK", "ACCESS", "OTHER"
  subcategory        String?
  slaDueDate         DateTime?
  attachmentUrl      String?  @db.LongText
  sourceDepartmentId String?
  targetDepartmentId String?

  userId String
  user   User   @relation("UserTickets", fields: [userId], references: [id])

  agentId String?
  agent   User?  @relation("AgentTickets", fields: [agentId], references: [id])

  sourceDepartment Department? @relation("TicketSourceDepartment", fields: [sourceDepartmentId], references: [id], onDelete: SetNull)
  targetDepartment Department? @relation("TicketTargetDepartment", fields: [targetDepartmentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments  Comment[]
  transfers TicketTransfer[]

  @@index([status])
  @@index([priority])
  @@index([userId])
  @@index([agentId])
  @@index([createdAt])
  @@index([sourceDepartmentId])
  @@index([targetDepartmentId])
}

model TicketTransfer {
  id              String   @id @default(uuid())
  ticketId        String
  fromDepartmentId String?
  toDepartmentId   String?
  requestedById   String
  status          String   @default("PENDING") // "PENDING", "ACCEPTED", "REJECTED", "COMPLETED"
  note            String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ticket         Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromDepartment  Department? @relation("TransferFromDepartment", fields: [fromDepartmentId], references: [id], onDelete: SetNull)
  toDepartment    Department? @relation("TransferToDepartment", fields: [toDepartmentId], references: [id], onDelete: SetNull)
  requestedBy     User        @relation("TransferRequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
}

model Comment {
  id            String   @id @default(uuid())
  ticketId      String
  ticket        Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  message       String   @db.Text
  isInternal    Boolean  @default(false)
  attachmentUrl String?  @db.LongText
  createdAt     DateTime @default(now())
}

model WebhookConfig {
  id        String   @id @default(uuid())
  name      String
  url       String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
